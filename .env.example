# RivalsMeta refresh and shared cache
RIVALSMETA_BASE_URL=https://rivalsmeta.com
RIVALSMETA_REFRESH_INTERVAL_HOURS=24
RIVALSMETA_MIN_REQUEST_DELAY_MS=2000
# Recommended for Vercel/serverless: Upstash REST
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# TCP fallback only. Must use redis:// or rediss://, never https://
REDIS_URL=rediss://
# Manual administrator refresh requests
ADMIN_SECRET=
# Vercel Cron Bearer token (automatically sent by Vercel)
CRON_SECRET=
# Query token authentication is legacy fallback only and is not recommended in production.

# Deprecated legacy official/API fallback variables (kept for existing deployments)
USE_MOCK_DATA=false
MARVEL_RIVALS_API_BASE_URL=
MARVEL_RIVALS_API_KEY=
MARVEL_RIVALS_DAILY_API_LIMIT=
PLAYER_REFRESH_COOLDOWN_SECONDS=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
